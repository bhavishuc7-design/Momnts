# Change the file name to .env

# This is prisma URL name should be DATABASE_URL
# DATABASE_URL=""

# This is for local database URL name should be DATABASE_URL
DATABASE_URL=""
JWT_SECRET="your-secret-key-change-this"
PORT=3000
PYTHON_SERVICE_URL="http://localhost:8000"

R2_ACCOUNT_ID="your-account-ID"
R2_ACCESS_KEY_ID="your-access-key-after-creating-api-key"
R2_SECRET_ACCESS_KEY="your-secret-access-key-after-creating-api-key"
R2_BUCKET_NAME="your-bucket-name"
R2_PUBLIC_URL="your-public-after-creating-bucket"
R2_ENDPOINT_URL="your-end-point-url-after-creating-api" 